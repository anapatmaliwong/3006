# ══════════════════════════════════════════════
# 3006 Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ══════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d

# Admin credentials (stored server-side ONLY — never sent to browser)
ADMIN_STUDENT_NO=27
ADMIN_PASSWORD=anapatmaliwong59892

# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=ac-library-c63ee
FIREBASE_DATABASE_URL=https://ac-library-c63ee-default-rtdb.firebaseio.com
FIREBASE_CLIENT_EMAIL=REPLACE_WITH_SERVICE_ACCOUNT_EMAIL
FIREBASE_PRIVATE_KEY="REPLACE_WITH_PRIVATE_KEY_FROM_SERVICE_ACCOUNT_JSON"

# Gemini AI
GEMINI_API_KEY=AQ.Ab8RN6KrY8FaAS5LMJefKwQt6W5FdXJSZ9sdjNn8KqIUqxe5yw

# Rate Limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
